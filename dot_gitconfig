    name = Smith Alike
[credential]
    helper = store
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    light = false
    side-by-side = true
    true-color = always
    line-numbers = true
[merge]
    conflictStyle = zdiff3
[diff]
    colorMoved = default
[alias]
    dft = -c diff.external=difft diff
